{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@berry-chart-test-lib/source"],
    "baseUrl": ".",
    "paths": {
      "@berry-org-test/chart-core": ["./libs/chart-core/src/index.ts"],
      "@berry-org-test/chart-react": ["./libs/chart-react/src/index.ts"]
    }
  }
}
